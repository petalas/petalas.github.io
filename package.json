{
  "name": "petalas.dev",
  "private": true,
  "description": "Nick's Personal Website",
  "author": "Nick Petalas <webmasternikos@gmail.com>",
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-sitemap.js && tsc && vite build",
    "preview": "vite preview",
    "lint": "prettier --check \"**/*.{js,jsx,ts,tsx,css,json,md}\"",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,css,json,md}\"",
    "generate-cv": "node cv/generate-cv.mjs",
    "sitemap": "node scripts/generate-sitemap.js",
    "add-domain": "echo \"petalas.dev\" > ./dist/CNAME",
    "deploy": "node scripts/generate-sitemap.js && tsc && vite build && echo \"petalas.dev\" > ./dist/CNAME && gh-pages -d dist -b deploy-branch -f"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "gh-pages": "^6.3.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "puppeteer": "^24.40.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.3"
  }
}
